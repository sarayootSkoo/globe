{
  "name": "knowledge-graph",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 4002",
    "build": "node scripts/build-graph-data.mjs --out dist/graph-data.json && vite build",
    "preview": "vite preview --port 4003",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "gen": "node scripts/build-graph-data.mjs",
    "gen:dist": "node scripts/build-graph-data.mjs --out dist/graph-data.json",
    "watch": "node scripts/watch-docs.mjs",
    "dev:watch": "node scripts/watch-docs.mjs & vite --port 4002",
    "event-server": "node scripts/event-server.mjs",
    "dev:full": "node scripts/event-server.mjs & vite --port 4002",
    "start:all": "node scripts/event-server.mjs & vite --port 4002",
    "migrate": "node scripts/migrate-to-sqlite.mjs",
    "seed": "node scripts/seed-db.mjs"
  },
  "dependencies": {
    "@secure-storage/common": "^1.0.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "d3": "^7.9.0",
    "marked": "^12.0.0",
    "three": "0.160.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/d3": "^7.4.0",
    "@types/three": "^0.160.0",
    "node-pty": "^1.1.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.5",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "node-pty"
    ]
  }
}